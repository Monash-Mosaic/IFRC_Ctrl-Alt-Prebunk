\\",\\\"analytics\\\":\\\"Analytique\\\",\\\"share\\\":\\\"Partager\\\",\\\"profile\\\":\\\"Profil\\\"},\\\"header\\\":{\\\"points\\\":\\\"Points\\\",\\\"credibility\\\":\\\"Crédibilité\\\",\\\"title\\\":\\\"CTRL + ALT + PREBUNK\\\",\\\"titleMobile\\\":\\\"US!\\\",\\\"ifrcLogoAlt\\\":\\\"Académie Solferino de la FICR\\\",\\\"monashLogoAlt\\\":\\\"MOSAIC de l'Université Monash\\\"},\\\"common\\\":{\\\"loading\\\":\\\"Chargement...\\\",\\\"error\\\":\\\"Une erreur s'est produite\\\"},\\\"underDevelopment\\\":{\\\"title\\\":\\\"En Développement\\\",\\\"message\\\":\\\"Cette page est actuellement en développement. Revenez bientôt!\\\"},\\\"metadata\\\":{\\\"title\\\":\\\"CTRL + ALT + PREBUNK\\\",\\\"description\\\":\\\"Académie Solferino de la FICR - Plateforme de vérification des faits et d'éducation aux médias\\\"},\\\"chat\\\":{\\\"illustrationAlt\\\":\\\"Réseau de personnes et de connexions de médias sociaux\\\",\\\"startOnboarding\\\":\\\"Commencer le chat d'intégration avec Paula\\\",\\\"skip\\\":\\\"Ignorer\\\",\\\"list\\\":{\\\"title\\\":\\\"Messages\\\",\\\"paula\\\":\\\"Paula\\\",\\\"alex\\\":\\\"Alex\\\",\\\"newMessage\\\":\\\"Nouveau message\\\"},\\\"onboarding\\\":{\\\"step1\\\":{\\\"greeting\\\":\\\"Salut ! Bienvenue dans le fil d'actualité. Je suis Paula, et je vais t'aider à naviguer dans ce monde sauvage d'informations en ligne. 👋\\\",\\\"option1\\\":\\\"Allons-y ! Je suis prêt.🚀\\\",\\\"option2\\\":\\\"Ça a l'air compliqué...🤔\\\",\\\"option3\\\":\\\"Montre-moi juste comment ça fonctionne !🎮\\\"},\\\"step2\\\":{\\\"explanation\\\":\\\"Ne t'inquiète pas - tu peux le faire ! Tu vois ce post ci-dessous ? Quelqu'un partage quelque chose sur le changement climatique. Ton travail : décider si c'est fiable ou totalement absurde.\\\",\\\"option1\\\":\\\"Je peux déjà repérer les fausses informations !\\\",\\\"option2\\\":\\\"Compris ! Garder les bonnes choses, dénoncer les fausses.\\\",\\\"option3\\\":\\\"Attends, comment je sais ce qui est réel ?\\\"},\\\"step3\\\":{\\\"tips\\\":\\\"Exactement ! Voici le secret : Cherche un langage exagéré, des sources manquantes, et des choses qui semblent TROP folles pour être vraies. Essaie le premier post - je te dirai comment tu t'en es sorti !\\\",\\\"option1\\\":\\\"D'accord, j'entre dans le fil maintenant !\\\",\\\"option2\\\":\\\"Montre-moi un exemple d'abord ?\\\"},\\\"example\\\":{\\\"message\\\":\\\"Voici un exemple de post avec des explications. Remarque le langage exagéré et les sources manquantes - ce sont des signaux d'alarme !\\\"},\\\"completed\\\":{\\\"message\\\":\\\"Le jeu commence ! Tu es prêt à naviguer dans le fil et identifier la désinformation. Bonne chance ! 🎮\\\"}}},\\\"prebunking\\\":{\\\"modalLabel\\\":\\\"Modal d'information de prébunking\\\",\\\"header\\\":{\\\"holdOn\\\":\\\"Attendez !\\\",\\\"misleading\\\":\\\"C'est trompeur !\\\"},\\\"body\\\":{\\\"techniquePrefix\\\":\\\"Cette publication utilise\\\",\\\"context\\\":\\\"La météo n'est pas la même chose que le climat. Ne laissez pas les incidents isolés distraire des données à long terme dans le Rapport mondial sur les catastrophes.\\\",\\\"dataLink\\\":\\\"Voir les données de la FICR sur les tendances croissantes des vagues de chaleur.\\\"},\\\"continueButton\\\":\\\"Compris ! Continuer\\\"},\\\"errors\\\":{\\\"404\\\":{\\\"title\\\":\\\"Page introuvable\\\",\\\"description\\\":\\\"La page que vous recherchez n'existe pas.\\\",\\\"backHome\\\":\\\"Retour à l'accueil\\\"},\\\"500\\\":{\\\"title\\\":\\\"Erreur du serveur\\\",\\\"description\\\":\\\"Une erreur s'est produite. Veuillez réessayer plus tard.\\\",\\\"reload\\\":\\\"Recharger\\\"}}},\\\"now\\\":\\\"$undefined\\\",\\\"timeZone\\\":\\\"Australia/Melbourne\\\",\\\"children\\\":[\\\"$L17\\\",[\\\"$\\\",\\\"$L18\\\",null,{}],[\\\"$\\\",\\\"$L19\\\",null,{}],[\\\"$\\\",\\\"main\\\",null,{\\\"id\\\":\\\"root\\\",\\\"className\\\":\\\"min-h-screen bg-white pt-24 pb-16 md:pb-0 md:pl-20\\\",\\\"children\\\":[\\\"$\\\",\\\"$L2\\\",null,{\\\"parallelRout