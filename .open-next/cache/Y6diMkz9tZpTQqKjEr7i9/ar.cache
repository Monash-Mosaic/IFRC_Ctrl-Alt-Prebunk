className\":\"geist_a71539c9-module__T19VSG__variable geist_mono_8d43a2aa-module__8Li5zG__variable antialiased rtl\",\"children\":[\"$\",\"$L2\",null,{\"locale\":\"ar\",\"messages\":{\"nav\":{\"home\":\"الرئيسية\",\"chat\":\"المحادثة\",\"analytics\":\"التحليلات\",\"share\":\"مشاركة\",\"profile\":\"الملف الشخصي\"},\"header\":{\"points\":\"النقاط\",\"credibility\":\"المصداقية\",\"title\":\"CTRL + ALT + PREBUNK\",\"titleMobile\":\"US!\",\"ifrcLogoAlt\":\"أكاديمية سولفيرينو للاتحاد الدولي\",\"monashLogoAlt\":\"جامعة موناش MOSAIC\"},\"common\":{\"loading\":\"جاري التحميل...\",\"error\":\"حدث خطأ\"},\"underDevelopment\":{\"title\":\"قيد التطوير\",\"message\":\"هذه الصفحة قيد التطوير حالياً. يرجى العودة لاحقاً!\"},\"metadata\":{\"title\":\"CTRL + ALT + PREBUNK\",\"description\":\"أكاديمية سولفيرينو للاتحاد الدولي - منصة للتحقق من الحقائق ومحو الأمية الإعلامية\"},\"chat\":{\"illustrationAlt\":\"شبكة من الأشخاص وروابط وسائل التواصل الاجتماعي\",\"startOnboarding\":\"بدء محادثة التعريف مع باولا\",\"skip\":\"تخطي\",\"list\":{\"title\":\"الرسائل\",\"paula\":\"باولا\",\"alex\":\"أليكس\",\"newMessage\":\"رسالة جديدة\"},\"onboarding\":{\"step1\":{\"greeting\":\"مرحباً! أهلاً بك في الخلاصة. أنا باولا، وسأساعدك على التنقل في هذا العالم الواسع من المعلومات عبر الإنترنت. 👋\",\"option1\":\"لنفعل ذلك! أنا مستعد.🚀\",\"option2\":\"يبدو هذا معقداً...🤔\",\"option3\":\"فقط أرني كيف يعمل!🎮\"},\"step2\":{\"explanation\":\"لا تقلق - يمكنك فعل ذلك! هل ترى ذلك المنشور أدناه؟ شخص ما يشارك شيئاً عن تغير المناخ. مهمتك: قرر ما إذا كان موثوقاً أم هراءً تماماً.\",\"option1\":\"يمكنني بالفعل اكتشاف الأخبار المزيفة!\",\"option2\":\"فهمت! احتفظ بالأشياء الجيدة، اكشف عن المزيفة.\",\"option3\":\"انتظر، كيف أعرف ما هو حقيقي؟\"},\"step3\":{\"tips\":\"بالضبط! إليك السر: ابحث عن اللغة المبالغ فيها، والمصادر المفقودة، والأشياء التي تبدو مجنونة جداً لدرجة لا يمكن أن تكون صحيحة. جرب المنشور الأول - سأخبرك كيف أديت!\",\"option1\":\"حسناً، أدخل الخلاصة الآن!\",\"option2\":\"أرني مثالاً أولاً؟\"},\"example\":{\"message\":\"إليك مثال على منشور مع شرح. لاحظ اللغة المبالغ فيها والمصادر المفقودة - هذه علامات خطر!\"},\"completed\":{\"message\":\"اللعبة تبدأ! أنت جاهز للتنقل في الخلاصة وتحديد المعلومات المضللة. حظاً موفقاً! 🎮\"}}},\"prebunking\":{\"modalLabel\":\"نافذة معلومات الوقاية من التضليل\",\"header\":{\"holdOn\":\"انتظر!\",\"misleading\":\"هذا مضلل!\"},\"body\":{\"techniquePrefix\":\"هذا المنشور يستخدم\",\"context\":\"الطقس ليس هو نفسه المناخ. لا تدع الحوادث المعزولة تصرف انتباهك عن البيانات طويلة الأجل في تقرير الكوارث العالمي.\",\"dataLink\":\"اطلع على بيانات الاتحاد الدولي حول الاتجاهات المتزايدة لموجات الحر.\"},\"continueButton\":\"فهمت! متابعة\"},\"errors\":{\"404\":{\"title\":\"الصفحة غير موجودة\",\"description\":\"الصفحة التي تبحث عنها غير موجودة.\",\"backHome\":\"العودة إلى الصفحة الرئيسية\"},\"500\":{\"title\":\"خطأ في الخادم\",\"description\":\"حدث خطأ. يرجى المحاولة مرة أخرى لاحقًا.\",\"reload\":\"إعادة التحميل\"}}},\"timeZone\":\"Australia/Melbourne\",\"children\":[[\"$\",\"header\",null,{\"className\":\"fixed top-0 left-0 right-0 z-50 h-14 bg-white\",\"children\":[\"$\",\"div\",null,{\"className\":\"flex h-full items-center justify-center md:justify-between md:px-6\",\"children\":[[\"$\",\"div\",null,{\"className\":\"hidden items-center gap-2 md:flex\",\"children\":[\"$\",\"div\",null,{\"className\":\"flex items-center gap-1\",\"children\":[\"$\",\"$L3\",null,{\"href\":\"/ar\",\"localeCookie\":{\"name\":\"NEXT_LOCALE\",\"sameSite\":\"lax\"},\"children\":[\"$\",\"$L4\",null,{\"src\":\"/images/logos/IFRC-Solferino.png\",\"alt\":\"أكاديمية سولفيرينو للاتحاد الدولي\",\"height\":61.35,\"width\":223.67,\"className\":\"h-8 w-auto\"}]}]}]}],[\"$\",\"div\",null,{\"className\":\"flex items-center gap-2\",\"children\":[\"$\",\"$L3\",null,{\"href\":\"/ar\",\"localeCookie\":\"$0:rsc:props:children:1:props:children:props:children:props:children:0:props:children:props:children:0:props:children:props:children:props:localeCookie\",\"className\":\"w-full\",\"children\":[\"$\",\"svg