"metadata\\\":{\\\"title\\\":\\\"CTRL + ALT + PREBUNK\\\",\\\"description\\\":\\\"أكاديمية سولفيرينو للاتحاد الدولي - منصة للتحقق من الحقائق ومحو الأمية الإعلامية\\\"},\\\"chat\\\":{\\\"illustrationAlt\\\":\\\"شبكة من الأشخاص وروابط وسائل التواصل الاجتماعي\\\",\\\"startOnboarding\\\":\\\"بدء محادثة التعريف مع باولا\\\",\\\"skip\\\":\\\"تخطي\\\",\\\"list\\\":{\\\"title\\\":\\\"الرسائل\\\",\\\"paula\\\":\\\"باولا\\\",\\\"alex\\\":\\\"أليكس\\\",\\\"newMessage\\\":\\\"رسالة جديدة\\\"},\\\"onboarding\\\":{\\\"step1\\\":{\\\"greeting\\\":\\\"مرحباً! أهلاً بك في الخلاصة. أنا باولا، وسأساعدك على التنقل في هذا العالم الواسع من المعلومات عبر الإنترنت. 👋\\\",\\\"option1\\\":\\\"لنفعل ذلك! أنا مستعد.🚀\\\",\\\"option2\\\":\\\"يبدو هذا معقداً...🤔\\\",\\\"option3\\\":\\\"فقط أرني كيف يعمل!🎮\\\"},\\\"step2\\\":{\\\"explanation\\\":\\\"لا تقلق - يمكنك فعل ذلك! هل ترى ذلك المنشور أدناه؟ شخص ما يشارك شيئاً عن تغير المناخ. مهمتك: قرر ما إذا كان موثوقاً أم هراءً تماماً.\\\",\\\"option1\\\":\\\"يمكنني بالفعل اكتشاف الأخبار المزيفة!\\\",\\\"option2\\\":\\\"فهمت! احتفظ بالأشياء الجيدة، اكشف عن المزيفة.\\\",\\\"option3\\\":\\\"انتظر، كيف أعرف ما هو حقيقي؟\\\"},\\\"step3\\\":{\\\"tips\\\":\\\"بالضبط! إليك السر: ابحث عن اللغة المبالغ فيها، والمصادر المفقودة، والأشياء التي تبدو مجنونة جداً لدرجة لا يمكن أن تكون صحيحة. جرب المنشور الأول - سأخبرك كيف أديت!\\\",\\\"option1\\\":\\\"حسناً، أدخل الخلاصة الآن!\\\",\\\"option2\\\":\\\"أرني مثالاً أولاً؟\\\"},\\\"example\\\":{\\\"message\\\":\\\"إليك مثال على منشور مع شرح. لاحظ اللغة المبالغ فيها والمصادر المفقودة - هذه علامات خطر!\\\"},\\\"completed\\\":{\\\"message\\\":\\\"اللعبة تبدأ! أنت جاهز للتنقل في الخلاصة وتحديد المعلومات المضللة. حظاً موفقاً! 🎮\\\"}}},\\\"prebunking\\\":{\\\"modalLabel\\\":\\\"نافذة معلومات الوقاية من التضليل\\\",\\\"header\\\":{\\\"holdOn\\\":\\\"انتظر!\\\",\\\"misleading\\\":\\\"هذا مضلل!\\\"},\\\"body\\\":{\\\"techniquePrefix\\\":\\\"هذا المنشور يستخدم\\\",\\\"context\\\":\\\"الطقس ليس هو نفسه المناخ. لا تدع الحوادث المعزولة تصرف انتباهك عن البيانات طويلة الأجل في تقرير الكوارث العالمي.\\\",\\\"dataLink\\\":\\\"اطلع على بيانات الاتحاد الدولي حول الاتجاهات المتزايدة لموجات الحر.\\\"},\\\"continueButton\\\":\\\"فهمت! متابعة\\\"},\\\"errors\\\":{\\\"404\\\":{\\\"title\\\":\\\"الصفحة غير موجودة\\\",\\\"description\\\":\\\"الصفحة التي تبحث عنها غير موجودة.\\\",\\\"backHome\\\":\\\"العودة إلى الصفحة الرئيسية\\\"},\\\"500\\\":{\\\"title\\\":\\\"خطأ في الخادم\\\",\\\"description\\\":\\\"حدث خطأ. يرجى المحاولة مرة أخرى لاحقًا.\\\",\\\"reload\\\":\\\"إعادة التحميل\\\"}}},\\\"now\\\":\\\"$undefined\\\",\\\"timeZone\\\":\\\"Australia/Melbourne\\\",\\\"children\\\":[\\\"$L15\\\",[\\\"$\\\",\\\"$L16\\\",null,{}],[\\\"$\\\",\\\"$L17\\\",null,{}],[\\\"$\\\",\\\"main\\\",null,{\\\"id\\\":\\\"root\\\",\\\"className\\\":\\\"min-h-screen bg-white pt-24 pb-16 md:pb-0 md:pr-20\\\",\\\"children\\\":[\\\"$\\\",\\\"$L2\\\",null,{\\\"parallelRouterKey\\\":\\\"children\\\",\\\"error\\\":\\\"$18\\\",\\\"errorStyles\\\":[],\\\"errorScripts\\\":[[\\\"$\\\",\\\"script\\\",\\\"script-0\\\",{\\\"src\\\":\\\"/_next/static/chunks/02p3r8.b~r.xa.js\\\",\\\"async\\\":true}]],\\\"template\\\":[\\\"$\\\",\\\"$L4\\\",null,{}],\\\"templateStyles\\\":\\\"$undefined\\\",\\\"templateScripts\\\":\\\"$undefined\\\",\\\"notFound\\\":[\\\"$L19\\\",[]],\\\"forbidden\\\":\\\"$undefined\\\",\\\"unauthorized\\\":\\\"$undefined\\\"}]}]]}]\\n\"])</script><script>self.__next_f.push([1,\"15:[\\\"$\\\",\\\"header\\\",null,{\\\"className\\\":\\\"fixed top-0 left-0 right-0 z-50 h-14 bg-white\\\",\\\"children\\\":[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"flex h-full items-center justify-center md:justify-between md:px-6\\\",\\\"children\\\":[[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"hidden items-center gap-2 md:flex\\\",\\\"children\\\":[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"flex items-center gap-1\\\",\\\"children\\\":\\\"$L1a\\\"}]}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"flex items-center gap-2\\\",